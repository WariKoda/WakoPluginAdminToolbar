{% block wako_admin_toolbar_settings_index %}
<sw-page class="wako-admin-toolbar-settings-index">
    <template #smart-bar-header>
        <h2>{{ $tc('wako-admin-toolbar.settings.moduleTitle') }}</h2>
    </template>

    <template #content>
        <sw-card-view>
            <mt-card
                position-identifier="wako-admin-toolbar-settings-index"
                :title="$tc('wako-admin-toolbar.settings.cardTitle')"
                :is-loading="isLoading"
            >
                <p>{{ $tc('wako-admin-toolbar.settings.description') }}</p>

                <mt-switch
                    :model-value="toolbarEnabled"
                    :label="$tc('wako-admin-toolbar.profile.switchLabel')"
                    :help-text="$tc('wako-admin-toolbar.settings.switchHelpText')"
                    :disabled="!canEditToggle || isSaving || isLoading || undefined"
                    @update:model-value="onToolbarToggleChange"
                />

                <mt-banner :variant="toolbarStatusVariant">
                    {{ toolbarStatusMessage }}
                </mt-banner>
            </mt-card>

            <mt-card
                position-identifier="wako-admin-toolbar-settings-features"
                :title="$tc('wako-admin-toolbar.settings.featuresTitle')"
            >
                <p>{{ $tc('wako-admin-toolbar.settings.featuresDescription') }}</p>

                <sw-container columns="1fr 1fr" gap="16px">
                    <mt-switch
                        v-for="feature in featureSwitches"
                        :key="feature.name"
                        :model-value="featurePreferences[feature.name]"
                        :label="feature.label"
                        :help-text="feature.helpText"
                        :disabled="!canEditFeature(feature.name) || isSaving || isLoading || undefined"
                        @update:model-value="onFeatureToggleChange(feature.name, $event)"
                    />
                </sw-container>
            </mt-card>
        </sw-card-view>
    </template>
</sw-page>
{% endblock %}
