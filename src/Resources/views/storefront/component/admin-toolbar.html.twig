{% block wako_admin_toolbar %}
    {#
    Admin Toolbar — only becomes visible when JS confirms a valid admin session
    (bearerAuth cookie present + /api/_info/me returns 200).
    Always rendered as display:none to be cache-safe.
    #}

    {% set toolbarExtension = page.extensions.wakoAdminToolbar %}
    {% set adminBasePath = config('WakoPluginAdminToolbar.config.adminBasePath') %}
    {% set adminBasePath = adminBasePath is not empty ? adminBasePath : '/admin' %}
    {% if adminBasePath|slice(0, 1) != '/' %}
        {% set adminBasePath = '/admin' %}
    {% endif %}
    {% set adminBaseUrl = app.request.attributes.get('sw-sales-channel-absolute-base-url') ~ adminBasePath %}

    {% set pageType  = toolbarExtension ? toolbarExtension['pageType']  : 'generic' %}
    {% set entityId  = toolbarExtension ? toolbarExtension['entityId']  : null %}
    {% set parentId  = toolbarExtension ? toolbarExtension['parentId']  : null %}
    {% set cmsPageId = toolbarExtension ? toolbarExtension['cmsPageId'] : null %}
    {% set routeName = app.request.attributes.get('_route') %}

    {#
    /page/cms/{id} is rendered by CmsController::pageFull() which fires no
    PageLoadedEvent, so our subscriber never runs. Detect this route directly.
    #}
    {% if routeName == 'frontend.cms.page.full' %}
        {% set pageType  = 'cmsPage' %}
        {% set cmsPageId = app.request.attributes.get('id') %}
    {% endif %}

    {% set hasContextLink =
        (pageType == 'product' and entityId) or
        (pageType == 'navigation' and (cmsPageId or entityId)) or
        (pageType == 'landingPage' and cmsPageId) or
        (pageType == 'cmsPage' and cmsPageId) %}

    {# Inline SVG icons — defined as set variables (macros don't work with sw_extends) #}
    {% set iconProducts %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-products"/>
        </svg>{% endset %}
    {% set iconChevronDown %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-chevron-down"/>
        </svg>{% endset %}
    {% set iconChevronUp %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-chevron-up"/>
        </svg>{% endset %}
    {% set iconCopy %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-copy"/>
        </svg>{% endset %}
    {% set iconContent %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-content"/>
        </svg>{% endset %}
    {% set iconSync %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-sync"/>
        </svg>{% endset %}
    {% set iconShoppingBag %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-shopping-bag"/>
        </svg>{% endset %}
    {% set iconPlug %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-plug"/>
        </svg>{% endset %}
    {% set iconCog %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-cog"/>
        </svg>{% endset %}
    {% set iconUser %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-user"/>
        </svg>{% endset %}
    {% set iconX %}
        <svg class="wako-admin-toolbar__icon" aria-hidden="true" focusable="false">
            <use href="#wako-icon-x"/>
        </svg>{% endset %}

    {% set shopwareIcon %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 34 34" class="wako-admin-toolbar__logo" aria-hidden="true"
             focusable="false">
            <path fill="currentColor"
                  d="M26.926772,30.0704562 C26.9875207,30.1161711 27.0237245,30.1888855 27.0234177,30.2652816 C27.0231109,30.3413709 26.9862935,30.4137784 26.9252379,30.4591865 C24.0010161,32.6234359 20.5291355,33.7672297 16.8851336,33.7672297 C12.3743887,33.7672297 8.13425177,32.0113467 4.9452515,28.82296 C1.75625123,25.6345734 6.13623296e-05,21.3944364 6.13623296e-05,16.8839984 C6.13623296e-05,12.374174 1.75625123,8.13434381 4.9452515,4.94534354 C8.13425177,1.75634328 12.3746955,0.000153405824 16.8851336,0.000153405824 C21.0583856,0.000153405824 25.0641185,1.53543889 28.1644502,4.32312952 C28.2442212,4.39461664 28.2672321,4.50844376 28.2221308,4.60539624 C28.1782567,4.70020104 28.0760884,4.75788163 27.9699316,4.74376829 C26.7669231,4.57870362 25.4681894,4.49494404 24.1093206,4.49494404 C19.1917435,4.49494404 15.1988968,5.59148887 12.5624643,7.66676286 C10.2113666,9.5171439 8.96877945,12.0774871 8.96877945,15.0710484 C8.96877945,18.4085455 10.2460363,21.0471256 12.8735713,23.1383538 C15.1927605,24.9838259 18.2817402,26.1819254 21.0071481,27.2385847 C23.2968834,28.1268044 25.4595987,28.9653206 26.926772,30.0704562 Z M33.6964176,15.3238611 C33.7433598,15.8610883 33.7669843,16.3860431 33.7669843,16.8836916 C33.7669843,19.0031464 33.3782539,21.0738182 32.6115316,23.0383332 C32.5860662,23.1033773 32.5336015,23.154308 32.4679438,23.1782393 C32.441558,23.1877505 32.4139449,23.1923527 32.3857182,23.1923527 C32.3446055,23.1923527 32.3037995,23.1819211 32.2679026,23.1619783 C30.260434,22.048252 28.0734805,21.2327467 25.9586278,20.4439339 C21.8544084,18.9135574 18.3107339,17.5918128 18.3107339,14.6918292 C18.3107339,13.6566467 18.7436451,12.7751768 19.563139,12.1422244 C20.5093462,11.411399 21.9258955,11.0407705 23.7738221,11.0407705 C27.2364984,11.0407705 30.0861649,12.2333474 33.6095899,15.157876 C33.6592934,15.1989888 33.690895,15.2597375 33.6964176,15.3238611 Z"/>
        </svg>
    {% endset %}

    {% sw_include '@WakoPluginAdminToolbar/storefront/component/admin-toolbar-icons.html.twig' %}

    <div id="wako-admin-toolbar"
         class="wako-admin-toolbar wako-admin-toolbar--hidden"
         data-admin-toolbar="true"
         data-admin-base-url="{{ adminBaseUrl }}"
         data-rules-show-all-label="{{ 'adminToolbar.showAllRules'|trans|striptags }}">

        {# Full toolbar — shown when expanded #}
        <div class="wako-admin-toolbar__inner">

            <div class="wako-admin-toolbar__left">
                <a href="{{ adminBaseUrl }}#/sw/dashboard/index"
                   class="wako-admin-toolbar__home"
                   target="_blank"
                   rel="noopener noreferrer"
                   title="{{ 'adminToolbar.goToDashboard'|trans|striptags }}">
                    {{ shopwareIcon }}
                </a>

                <span class="wako-admin-toolbar__nav-links">
                <a href="{{ adminBaseUrl }}#/sw/product/index"
                   target="_blank" rel="noopener noreferrer"
                   class="wako-admin-toolbar__link"
                   title="{{ 'adminToolbar.catalogues'|trans|striptags }}">{{ iconProducts }}</a>
                <a href="{{ adminBaseUrl }}#/sw/order/index"
                   target="_blank" rel="noopener noreferrer"
                   class="wako-admin-toolbar__link"
                   title="{{ 'adminToolbar.orders'|trans|striptags }}">{{ iconShoppingBag }}</a>
                <a href="{{ adminBaseUrl }}#/sw/extension/my-extensions/listing"
                   target="_blank" rel="noopener noreferrer"
                   class="wako-admin-toolbar__link"
                   title="{{ 'adminToolbar.extensions'|trans|striptags }}">{{ iconPlug }}</a>
                <a href="{{ adminBaseUrl }}#/sw/settings/index"
                   target="_blank" rel="noopener noreferrer"
                   class="wako-admin-toolbar__link"
                   title="{{ 'adminToolbar.settings'|trans|striptags }}">{{ iconCog }}</a>
            </span>

            </div>

            {% if hasContextLink %}
                <div class="wako-admin-toolbar__center">
                    {% if pageType == 'product' and entityId %}
                        {% set targetId = parentId ?? entityId %}
                        {% if parentId %}
                            <span class="wako-admin-toolbar__dropdown"
                                  data-toolbar-feature="edit-product"
                                  data-toolbar-variants="{{ parentId }}">
                            <a href="{{ adminBaseUrl }}#/sw/product/detail/{{ targetId }}"
                               target="_blank" rel="noopener noreferrer"
                               class="wako-admin-toolbar__link wako-admin-toolbar__dropdown-trigger">
                                {{ iconProducts }} {{ 'adminToolbar.editProduct'|trans|striptags }} {{ iconChevronDown }}
                            </a>
                            <div class="wako-admin-toolbar__dropdown-menu"></div>
                        </span>
                        {% else %}
                            <a href="{{ adminBaseUrl }}#/sw/product/detail/{{ targetId }}"
                               target="_blank" rel="noopener noreferrer"
                               class="wako-admin-toolbar__link"
                               data-toolbar-feature="edit-product">
                                {{ iconProducts }} {{ 'adminToolbar.editProduct'|trans|striptags }}
                            </a>
                        {% endif %}
                        {% if cmsPageId %}
                            <a href="{{ adminBaseUrl }}#/sw/cms/detail/{{ cmsPageId }}" target="_blank"
                               rel="noopener noreferrer"
                               class="wako-admin-toolbar__link"
                               data-toolbar-feature="edit-cms-page">{{ iconContent }} {{ 'adminToolbar.editLayout'|trans|striptags }}</a>
                        {% endif %}
                    {% elseif pageType == 'navigation' and cmsPageId %}
                        <a href="{{ adminBaseUrl }}#/sw/cms/detail/{{ cmsPageId }}" target="_blank"
                           rel="noopener noreferrer"
                           class="wako-admin-toolbar__link"
                           data-toolbar-feature="edit-cms-page">{{ iconContent }} {{ 'adminToolbar.editShoppingExperience'|trans|striptags }}</a>
                    {% elseif pageType == 'navigation' and entityId %}
                        <a href="{{ adminBaseUrl }}#/sw/category/index/{{ entityId }}" target="_blank"
                           rel="noopener noreferrer"
                           class="wako-admin-toolbar__link"
                           data-toolbar-feature="edit-category">{{ iconContent }} {{ 'adminToolbar.editCategory'|trans|striptags }}</a>
                    {% elseif pageType == 'landingPage' and cmsPageId %}
                        <a href="{{ adminBaseUrl }}#/sw/cms/detail/{{ cmsPageId }}" target="_blank"
                           rel="noopener noreferrer"
                           class="wako-admin-toolbar__link"
                           data-toolbar-feature="edit-landing-page">{{ iconContent }} {{ 'adminToolbar.editLandingPage'|trans|striptags }}</a>
                    {% elseif pageType == 'cmsPage' and cmsPageId %}
                        <a href="{{ adminBaseUrl }}#/sw/cms/detail/{{ cmsPageId }}" target="_blank"
                           rel="noopener noreferrer"
                           class="wako-admin-toolbar__link"
                           data-toolbar-feature="edit-cms-page">{{ iconContent }} {{ 'adminToolbar.editPage'|trans|striptags }}</a>
                    {% endif %}
                </div>
            {% endif %}

            <div class="wako-admin-toolbar__right">

                {# Route name — stripped of "frontend." prefix #}
                {% if routeName %}
                    <span class="wako-admin-toolbar__route wako-admin-toolbar__route--desktop"
                          title="{{ routeName }}">{{ routeName|replace({'frontend.': ''}) }}</span>
                {% endif %}

                <span class="wako-admin-toolbar__sep wako-admin-toolbar__sep--desktop" aria-hidden="true"></span>

                {# Copy entity ID — only rendered when entityId is available #}
                {% if entityId %}
                    <button class="wako-admin-toolbar__btn wako-admin-toolbar__btn--desktop"
                            data-toolbar-copy-id="true"
                            data-entity-id="{{ entityId }}"
                            type="button"
                            title="{{ 'adminToolbar.copyId'|trans|striptags }}: {{ entityId }}">{{ iconCopy }}
                        #{{ entityId|slice(0, 8) }}</button>

                    <span class="wako-admin-toolbar__sep wako-admin-toolbar__sep--desktop" aria-hidden="true"></span>
                {% endif %}

                {# Clear all caches #}
                <button class="wako-admin-toolbar__btn wako-admin-toolbar__btn--from-md"
                        data-toolbar-feature="clear-cache"
                        data-toolbar-clear-cache="true"
                        type="button"
                        title="{{ 'adminToolbar.clearCache'|trans|striptags }}">{{ iconSync }}</button>

                <span class="wako-admin-toolbar__sep wako-admin-toolbar__sep--from-md" aria-hidden="true"></span>

                <span class="wako-admin-toolbar__dropdown wako-admin-toolbar__dropdown--align-right"
                      data-toolbar-feature="customer-context"
                      data-toolbar-customer-dropdown="true">
                <span
                    class="wako-admin-toolbar__link wako-admin-toolbar__dropdown-trigger wako-admin-toolbar__dropdown-trigger--static"
                    tabindex="0"
                    role="button"
                    aria-haspopup="true"
                    title="{{ 'adminToolbar.customer'|trans|striptags }}">
                    {{ iconUser }} {{ iconChevronDown }}
                </span>

                <div class="wako-admin-toolbar__dropdown-menu wako-admin-toolbar__dropdown-menu--info">
                    <div class="wako-admin-toolbar__dropdown-section">
                        <div
                            class="wako-admin-toolbar__dropdown-label">{{ 'adminToolbar.customerName'|trans|striptags }}</div>
                        <div class="wako-admin-toolbar__dropdown-value" data-toolbar-customer-name="true"></div>
                    </div>

                    <div class="wako-admin-toolbar__dropdown-section">
                        <div
                            class="wako-admin-toolbar__dropdown-label">{{ 'adminToolbar.customerNumber'|trans|striptags }}</div>
                        <div class="wako-admin-toolbar__dropdown-copy-row">
                            <div class="wako-admin-toolbar__dropdown-value" data-toolbar-customer-number="true"></div>
                            <button class="wako-admin-toolbar__icon-btn wako-admin-toolbar__icon-btn--copy"
                                    data-toolbar-copy-customer-number="true"
                                    type="button"
                                    title="{{ 'adminToolbar.copyCustomerNumber'|trans|striptags }}"
                                    aria-label="{{ 'adminToolbar.copyCustomerNumber'|trans|striptags }}"
                                    disabled>
                                {{ iconCopy }}
                            </button>
                        </div>
                    </div>

                    <div class="wako-admin-toolbar__dropdown-section">
                        <div
                            class="wako-admin-toolbar__dropdown-label">{{ 'adminToolbar.email'|trans|striptags }}</div>
                        <div class="wako-admin-toolbar__dropdown-copy-row">
                            <div class="wako-admin-toolbar__dropdown-value" data-toolbar-customer-email="true"></div>
                            <button class="wako-admin-toolbar__icon-btn wako-admin-toolbar__icon-btn--copy"
                                    data-toolbar-copy-customer-email="true"
                                    type="button"
                                    title="{{ 'adminToolbar.copyEmail'|trans|striptags }}"
                                    aria-label="{{ 'adminToolbar.copyEmail'|trans|striptags }}"
                                    disabled>
                                {{ iconCopy }}
                            </button>
                        </div>
                    </div>

                    <div class="wako-admin-toolbar__dropdown-section" data-toolbar-feature="view-rules">
                        <div class="wako-admin-toolbar__dropdown-label">
                            {{ 'adminToolbar.activeRules'|trans|striptags }}
                            <span data-toolbar-customer-rules-count="true">(0)</span>
                        </div>
                        <ul class="wako-admin-toolbar__rule-list wako-admin-toolbar__rule-list--preview"
                            data-toolbar-customer-rules="true"></ul>
                        <button class="wako-admin-toolbar__dropdown-more-btn"
                                data-toolbar-customer-rules-more="true"
                                type="button"
                                hidden></button>
                        <div class="wako-admin-toolbar__dropdown-empty"
                             data-toolbar-customer-rules-empty="true">{{ 'adminToolbar.noActiveRules'|trans|striptags }}</div>
                    </div>
                </div>
            </span>

                <div class="wako-admin-toolbar__modal wako-admin-toolbar__modal--hidden"
                     data-toolbar-rules-modal="true"
                     role="dialog"
                     aria-modal="true"
                     aria-labelledby="wako-admin-toolbar-rules-modal-title">
                    <button class="wako-admin-toolbar__modal-backdrop"
                            data-toolbar-rules-modal-close="true"
                            type="button"
                            tabindex="-1"
                            aria-hidden="true"></button>
                    <div class="wako-admin-toolbar__modal-dialog" role="document">
                        <div class="wako-admin-toolbar__modal-header">
                            <div>
                                <div class="wako-admin-toolbar__modal-eyebrow">{{ 'adminToolbar.customer'|trans|striptags }}</div>
                                <h3 class="wako-admin-toolbar__modal-title" id="wako-admin-toolbar-rules-modal-title">
                                    {{ 'adminToolbar.activeRules'|trans|striptags }}
                                    <span data-toolbar-rules-modal-count="true">(0)</span>
                                </h3>
                            </div>
                            <button class="wako-admin-toolbar__modal-close"
                                    data-toolbar-rules-modal-close="true"
                                    type="button"
                                    title="{{ 'adminToolbar.closeRulesModal'|trans|striptags }}"
                                    aria-label="{{ 'adminToolbar.closeRulesModal'|trans|striptags }}">
                                {{ iconX }}
                            </button>
                        </div>
                        <div class="wako-admin-toolbar__modal-body">
                            <ul class="wako-admin-toolbar__rule-list wako-admin-toolbar__rule-list--modal"
                                data-toolbar-rules-modal-list="true"></ul>
                            <div class="wako-admin-toolbar__dropdown-empty"
                                 data-toolbar-rules-modal-empty="true">{{ 'adminToolbar.noActiveRules'|trans|striptags }}</div>
                        </div>
                    </div>
                </div>

                <span class="wako-admin-toolbar__sep" aria-hidden="true"></span>

                <button class="wako-admin-toolbar__toggle"
                        data-toolbar-toggle="true"
                        type="button"
                        title="{{ 'adminToolbar.collapseToolbar'|trans|striptags }}"
                        aria-label="{{ 'adminToolbar.collapseToolbar'|trans|striptags }}">{{ iconChevronUp }}</button>
            </div>
        </div>

        {# Collapsed bubble — fixed top-right, shown only when toolbar is collapsed #}
        <div class="wako-admin-toolbar__bubble"
             data-toolbar-tab="true"
             role="button"
             tabindex="0"
             title="{{ 'adminToolbar.expandToolbar'|trans|striptags }}"
             aria-label="{{ 'adminToolbar.expandToolbar'|trans|striptags }}">
            {{ shopwareIcon }}
        </div>

    </div>
{% endblock %}
